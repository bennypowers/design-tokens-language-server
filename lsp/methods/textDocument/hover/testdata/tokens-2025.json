{
  "$schema": "https://www.designtokens.org/schemas/2025.10.json",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [1, 0, 0],
        "alpha": 1
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "display-p3",
        "components": [0.8, 0.2, 0.5],
        "alpha": 0.5
      }
    },
    "brand": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0.4, 0.8],
        "alpha": 1,
        "hex": "#0066CC"
      }
    },
    "achromatic": {
      "$value": {
        "colorSpace": "oklch",
        "components": [0.5, 0, "none"]
      }
    },
    "no-alpha": {
      "$value": {
        "colorSpace": "srgb",
        "components": [1, 1, 1]
      }
    },
    "alias": {
      "$value": "{color.primary}"
    }
  },
  "spacing": {
    "large": {
      "$type": "dimension",
      "$value": {
        "value": 2,
        "unit": "rem"
      }
    }
  }
}
